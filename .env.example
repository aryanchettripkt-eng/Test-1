# ─────────────────────────────────────────────────────────────
# GEMINI AI (required for AI album sorting and memory search)
# ─────────────────────────────────────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
#
# For LOCAL development: rename this file to .env and fill in your key.
# For VERCEL deployment: add VITE_GEMINI_API_KEY in your project's
#   Settings → Environment Variables — do NOT use GEMINI_API_KEY,
#   only the VITE_ prefix works in Vite/Vercel browser builds.
#
VITE_GEMINI_API_KEY="your-gemini-api-key-here"

# ─────────────────────────────────────────────────────────────
# App URL (used for OAuth callbacks)
# Set to your Vercel deployment URL, e.g. https://reminiq.vercel.app
# ─────────────────────────────────────────────────────────────
APP_URL="http://localhost:3000"

# ─────────────────────────────────────────────────────────────
# Google Photos OAuth (optional)
# ─────────────────────────────────────────────────────────────
VITE_GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─────────────────────────────────────────────────────────────
# Spotify OAuth (optional)
# ─────────────────────────────────────────────────────────────
VITE_SPOTIFY_CLIENT_ID=""
SPOTIFY_CLIENT_SECRET=""
